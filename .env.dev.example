# SheLook 本地开发环境模板。
#
# 使用 `./setup.sh --env dev` 或 `./setup.ps1 -Env dev` 时，启动脚本会在
# `.env.dev` 缺失时复制本文件，并只为开发环境生成空的 SECRET_KEY。
# 本文件可安全提交；`.env.dev` 已被 Git 忽略，绝不应提交真实密钥。

COMPOSE_PROJECT_NAME=shelook-dev
APP_ENV=development
DEBUG=true
APP_VERSION=1.1.0
APP_REVISION=local
DEPLOYMENT_REGION=local
LOG_LEVEL=INFO

# Bind Nginx only to this machine by default.  Do not set 0.0.0.0 unless a
# server-level access gate has also been configured under nginx/external-access.
NGINX_HOST_BIND=127.0.0.1

# 留空即可由启动脚本首次生成；也可手动写入 `openssl rand -hex 32` 的结果。
SECRET_KEY=

# Optional regional build mirrors. Keep the defaults on globally reachable networks.
APT_MIRROR=deb.debian.org
UV_IMAGE=ghcr.io/astral-sh/uv:0.5.11
UV_DEFAULT_INDEX=

# 本地专用的容器凭据；不得复用于预发或生产。
POSTGRES_USER=shelook
POSTGRES_PASSWORD=shelook-dev
POSTGRES_DB=shelook
REDIS_PASSWORD=shelook-dev
MINIO_ROOT_USER=shelook
MINIO_ROOT_PASSWORD=shelook-dev-minio
MINIO_ACCESS_KEY=shelook
MINIO_SECRET_KEY=shelook-dev-minio
MINIO_BUCKET=product-images
MINIO_PRIVATE_BUCKET=product-images-private
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# 仅限开发体验：真实接入供应商前，允许生成服务返回明确标识的占位结果。
ALLOW_GENERATION_MOCKS=true
ENABLE_AUTH=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
TRUSTED_PROXY_HOSTS=127.0.0.1,::1,nginx

# 可选的本地调试配置。业务 API 凭据在网页“外部 API 配置”中维护。
METRICS_API_KEY=
C2PA_ENABLED=false
C2PA_REQUIRED=false
