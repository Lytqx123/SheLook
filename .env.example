# ============================================================
# SheLook 环境变量配置模板
#
# 本文件与 backend/app/config.py 的 Settings 类字段一一对应。
# 新增字段需同步更新此文件 + docker-compose.yml x-backend-env，保持配置一致。
#
# 标注说明:
#   [必填]  留空将导致应用启动失败或核心功能不可用
#   [推荐]  强烈建议配置；生产环境缺失会被启动检查拒绝或使对应通道明确失败
#   [可选]  已有合理默认值，可不配置
#
# 用法:
#   1. 推荐运行 .\setup.ps1 -Env dev 或 ./setup.sh --env dev。
#      脚本只会在缺失时从 .env.dev.example 创建 .env.dev，并显式传给 Compose。
#   2. 如需手动运行开发 Compose，可复制本文件到 .env.dev 并使用
#      docker compose --env-file .env.dev -f docker-compose.yml ...。
#   3. 预发/生产请使用 .env.staging.example / .env.prod.example；不要复制本文件
#      或把真实凭据写进仓库。
#
# 启动脚本只会为开发环境生成空的 SECRET_KEY；预发和生产必须从密钥管理系统写入。
# ============================================================


# ============================================================
# 一、运行环境
# ============================================================

# [可选] APP_ENV: development | staging | production
#   development — 启用调试特性（Swagger /docs 始终可访问）
#   production  — 强化安全约束（Swagger 需 DEBUG=true，启动时校验密钥强度）
APP_ENV=development

# [可选] DEBUG: 启用 Swagger 文档 (/docs) 与调试日志
# 生产环境建议 false，开发时设 true 便于排障
DEBUG=false

# [可选] 服务端口（容器内监听端口，通常无需修改）
API_PORT=8000
API_WORKERS=3

# [推荐] 部署版本与区域。发布流水线应写入不可变版本与 Git 提交号，便于追踪和回滚。
APP_VERSION=1.1.0
APP_REVISION=unknown
DEPLOYMENT_REGION=local

# [可选] 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ============================================================
# 二、安全密钥
# ============================================================

# [必填] 应用密钥，用于 JWT 签名与会话加密
# setup.ps1 / setup.sh 会自动生成 64 位随机密钥；也可手动设置：
#   PowerShell:  -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Min 0 -Max 16) })
#   Linux/macOS: openssl rand -hex 32
SECRET_KEY=
# 仅用于加密 Web 集成中心保存的第三方凭据；生产必须设置，并保留在密钥管理系统。
# 该值不是网页配置项，前端永不读取或回显。
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=

# [可选] 登录与 JWT 配置
# 后端通过 ENABLE_AUTH 控制企业身份源：
#   false — 本地开发默认值，使用开发账号进入演示/开发环境
#   true  — 生产环境必须配置至少一种外部身份源（飞书 OAuth 或通用企业 OIDC/SSO）
# 个人微信不是登录入口；企业微信是后续按组织需求配置的扩展，不在当前版本启用。
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
# 成员权限实时变更的 Redis 校验：每个 API worker 复用连接池；网络异常在生产环境快速拒绝，
# 避免请求堆积或继续使用过期权限。
AUTH_REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=1
AUTH_REDIS_SOCKET_TIMEOUT_SECONDS=1
AUTH_REDIS_MAX_CONNECTIONS=32
AUTH_REDIS_FAILURE_BACKOFF_SECONDS=2

# [可选] 是否启用企业认证
ENABLE_AUTH=false

# ---- 飞书 OAuth（可选）----
# 在飞书开放平台创建网页应用后填写。回调地址必须与飞书应用配置完全一致，
# 并指向前端统一回调页；服务器在回调后换取令牌，第三方令牌不会暴露给浏览器。
# 不要把 APP_SECRET 提交到仓库或写入 Kubernetes ConfigMap。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3000/login/callback
FEISHU_SCOPES=auth:user.id:read
# 显式映射：飞书 tenant_key -> SheLook 本地 tenant_id（JSON 对象）。
# 多租户部署必须配置映射，不能根据回调参数或用户资料自动选择租户。
FEISHU_TENANT_KEY_MAP={}
# 单租户允许名单（JSON 数组）。只配置允许名单时，登录仅进入 DEFAULT_TENANT_ID；
# 多租户必须只使用上面的显式映射，不能把允许名单与映射混用。
FEISHU_ALLOWED_TENANT_KEYS=[]

# ---- 通用企业 OIDC / SSO（可选）----
# 面向 Okta、Azure AD、Keycloak 等标准 OIDC 身份提供商。飞书不使用本组配置。
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=http://localhost:3000/login/callback
OIDC_SCOPES=openid profile email
OIDC_HTTP_TIMEOUT_SECONDS=10
# 外部组织 ID 到本地 tenant_id 的显式映射（JSON 对象）。留空时通用 OIDC
# 被限制到 DEFAULT_TENANT_ID，绝不直接信任 IdP 回传的任意本地租户 ID。
OIDC_TENANT_CLAIM_MAP={}
OIDC_TENANT_CLAIM=tenant_id
# 不论飞书还是 OIDC/SSO，用户均须先由管理员邀请并拥有有效的本地组织成员关系；
# 外部首次登录不会自动创建租户、成员或管理员权限。
DEFAULT_TENANT_ID=default
TENANT_ENFORCEMENT_ENABLED=true
TENANT_RLS_ENABLED=true


# ============================================================
# 三、数据库 (PostgreSQL 17 + pgvector 0.8.2)
# ============================================================

# [可选] 数据库凭据（docker-compose 读取这些变量初始化 PostgreSQL）
# 本地开发改为 localhost；生产环境务必使用强密码
POSTGRES_USER=shelook
POSTGRES_PASSWORD=shelook
POSTGRES_DB=shelook

# [可选] 异步驱动（FastAPI / SQLAlchemy async 使用）
# 格式: postgresql+asyncpg://用户:密码@主机:端口/数据库名
# Docker 环境用服务名 "postgres"；本地开发改为 "localhost"
DATABASE_URL=postgresql+asyncpg://shelook:shelook@postgres:5432/shelook

# [可选] 同步驱动（供兼容性脚本或外部管理工具使用；Alembic 使用 DATABASE_MIGRATION_URL）
DATABASE_URL_SYNC=postgresql+psycopg2://shelook:shelook@postgres:5432/shelook

# [生产部署] 仅迁移 Job 使用的 schema-owner 连接；API、Worker 和受控租户引导命令
# 只能使用 DATABASE_URL（无超级权限、无 BYPASSRLS 的运行账号）。留空时迁移沿用 DATABASE_URL，
# 仅适合本地开发。
DATABASE_MIGRATION_URL=

# [可选] 是否启用 pgvector 扩展
PGVECTOR_EXTENSION=true
DATABASE_ECHO=false
DASHBOARD_SUMMARY_CACHE_TTL_SECONDS=15
PRODUCT_LIST_CACHE_TTL_SECONDS=10

# [可选] 数据库连接池与查询保护。生产环境应按 API/Worker 副本总数和数据库最大连接数统一规划。
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=900
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_LOCK_TIMEOUT_MS=5000
DATABASE_APPLICATION_NAME=shelook-api


# ============================================================
# 四、缓存与消息队列 (Redis 8)
# ============================================================

# Redis 被多组件共用，通过不同 DB 编号隔离:
#   DB 0 — 通用缓存 + WebSocket Pub/Sub
#   DB 1 — Celery 消息队列 (Broker)
#   DB 2 — Celery 任务结果 (Result Backend)

# [可选] Redis 访问密码（需与 docker-compose redis requirepass 一致）
REDIS_PASSWORD=shelook-dev

# [可选] Redis 连接 URL（密码需与 REDIS_PASSWORD 一致）
REDIS_URL=redis://:shelook-dev@redis:6379/0
CELERY_BROKER_URL=redis://:shelook-dev@redis:6379/1
CELERY_RESULT_BACKEND=redis://:shelook-dev@redis:6379/2
# 任务确认与分队列弹性策略：生成任务不会挤占调度、模型与分析任务。
CELERY_VISIBILITY_TIMEOUT_SECONDS=3600
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_ORCHESTRATION_CONCURRENCY=4
CELERY_GENERATION_CONCURRENCY=2
CELERY_ANALYTICS_CONCURRENCY=2


# ============================================================
# 五、对象存储 (MinIO，S3 兼容)
# ============================================================

# Docker 环境用服务名 "minio"；端口 9000 (API) / 9001 (控制台)
# 使用社区维护的 pgsty/minio 分支，持续发布安全更新
MINIO_ROOT_USER=shelook
MINIO_ROOT_PASSWORD=shelook123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=shelook
MINIO_SECRET_KEY=shelook123
MINIO_BUCKET=product-images
MINIO_PRIVATE_BUCKET=product-images-private
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=3600
MINIO_SECURE=false


# ============================================================
# 六、AIGC 生图引擎
# ============================================================

# [可选] 单次生图超时（秒），超时后切换降级通道
REPLICATE_TIMEOUT=180

# Replicate、Gemini、Kling、Runway、Shopee、Amazon 的业务 API 凭据
# 请在管理员网页“系统集成 / 外部 API 配置”中填写。服务端会按租户加密保存，
# 这些业务密钥不再从环境变量读取。


# ---- 降级通道: Stable Diffusion WebUI (本地 GPU) ----
# 启用方式: .\setup.ps1 -WithSDWebUI  /  ./setup.sh --with-sdwebui
# [可选] SD WebUI 服务地址
SD_WEBUI_URL=http://sd-webui:7860
ALLOW_GENERATION_MOCKS=true
GENERATION_BATCH_CONCURRENCY=4
# Cost reservations are used for quota/budget guardrails before provider calls.
IMAGE_GENERATION_RESERVATION_CENTS=8
VIDEO_GENERATION_RESERVATION_CENTS=30
IMAGE_FETCH_ALLOWED_HOSTS=["placehold.co","replicate.delivery","pbxt.replicate.delivery","storage.googleapis.com","ai.googleusercontent.com"]
IMAGE_FETCH_TRUSTED_PRIVATE_HOSTS=[]
IMAGE_FETCH_MAX_BYTES=26214400
# Remote-image fetch guardrails. Keep redirects and request timeouts bounded to
# prevent a slow or hostile upstream from occupying application workers.
IMAGE_FETCH_TIMEOUT_SECONDS=30
IMAGE_FETCH_MAX_REDIRECTS=3
C2PA_ENABLED=false
C2PA_REQUIRED=false
C2PA_CERT_PATH=
C2PA_PRIVATE_KEY_PATH=
C2PA_SIGNING_ALGORITHM=ES256
C2PA_TIMESTAMP_AUTHORITY_URL=

# Fairness monitoring baselines. Replace these sample proportions with a
# reviewed, market-appropriate baseline before enabling governance reporting.
FAIRNESS_BASELINE_SOURCE=operator-configured baseline; validate with local legal/data owners
FAIRNESS_MARKET_BASELINES={"us":{"light":0.55,"medium":0.25,"dark":0.15,"no_person":0.05},"eu":{"light":0.65,"medium":0.20,"dark":0.10,"no_person":0.05},"me":{"light":0.30,"medium":0.50,"dark":0.15,"no_person":0.05},"seasia":{"light":0.10,"medium":0.60,"dark":0.25,"no_person":0.05},"default":{"light":0.40,"medium":0.35,"dark":0.20,"no_person":0.05}}
FAIRNESS_DEVIATION_THRESHOLD=0.30
FAIRNESS_MAX_CLASSIFICATIONS_PER_REQUEST=50

# Decision and experiment thresholds used by dashboards and auto-completion.
DASHBOARD_CTR_BASELINE=0.02
EXPERIMENT_COMPLETION_IMPRESSIONS=10000


# ============================================================
# 七、向量检索 (CLIP + pgvector HNSW)
# ============================================================

# [可选] CLIP 模型名（HuggingFace）
# CLIP-ViT-B/32 输出维度 = 512；首次启动自动下载 (~600MB)
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# [可选] HuggingFace 镜像站（国内直连稳定获取模型文件）
# docker-compose.yml 已内置此配置，此处用于本地直接运行（非 Docker）时参考
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ENABLE_HF_TRANSFER=0
# 禁用 Xet 协议，确保模型文件通过 HF_ENDPOINT 镜像站获取
HF_HUB_DISABLE_XET=1

# [可选] 向量维度，需与 CLIP_MODEL_NAME 输出维度一致
VECTOR_DIMENSION=512

# [可选] 图文匹配阈值（低于此分数判定为图文不匹配，触发 L1 合规告警）
IMAGE_TEXT_MATCH_THRESHOLD=0.25


# ============================================================
# 九、CORS 跨域
# ============================================================

# [可选] 允许的前端来源，JSON 数组或逗号分隔字符串
# 生产环境改为实际域名: ["https://shelook.example.com","https://www.shelook.example.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]


# ============================================================
# 十、限流
# ============================================================

# 单一 Redis 原子滑动窗口限流，所有 API 实例共享同一计数。
# [可选] 是否启用限流
RATE_LIMIT_ENABLED=true

# [可选] 滑动窗口内最大请求数
RATE_LIMIT_REQUESTS=600

# [可选] 滑动窗口大小（秒）
RATE_LIMIT_WINDOW=60
# Only honor forwarded client addresses from the reverse proxies listed here.
# Use a comma-separated list; do not include untrusted public hosts.
TRUSTED_PROXY_HOSTS=127.0.0.1,::1,nginx


# ============================================================
# 十一、预测服务降级值
# ============================================================

# [可选] 模型未训练时的 CTR 兜底预估值
FALLBACK_CTR=0.025

# [可选] 模型未训练时的爆款概率兜底预估值
FALLBACK_HIT_PROBABILITY=0.3


# ============================================================
# 十二、可观测性 (OpenTelemetry)
# ============================================================

# [可选] 是否启用分布式追踪
# 启用后自动插桩 FastAPI / SQLAlchemy / Redis / Celery / HTTPX
OTEL_ENABLED=false

# [可选] 服务名（出现在 trace 中）
OTEL_SERVICE_NAME=shelook-backend

# [可选] OTLP 导出端点（如 Jaeger / Tempo）
OTEL_EXPORTER_OTLP_ENDPOINT=


# ============================================================
# 十三、数据指标 API
# ============================================================

# [推荐] 数据导入 API 的 API Key（metrics API 鉴权）
# 为空时跳过鉴权（仅开发环境），生产环境务必设置强密钥
# 生成方式: openssl rand -hex 32
METRICS_API_KEY=

# Shopee 与 Amazon 的业务 API 凭据和站点信息在“外部 API 配置”页维护。
# Lazada 目前仅支持通过已授权数据源导入指标。
AMAZON_REPORT_POLL_SECONDS=5
AMAZON_REPORT_TIMEOUT_SECONDS=180
AMAZON_SYNC_MAX_DAYS=3


# ============================================================
# 十四、监控看板 (Phase 3)
# ============================================================

# [推荐] Grafana 管理员账号（默认 admin/admin）
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost/grafana/
