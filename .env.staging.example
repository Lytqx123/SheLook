# SheLook 预发环境模板。
#
# 创建 `.env.staging` 后，所有空值必须从受控的密钥管理系统写入；不要把真实值
# 提交到 Git。本模板采用已构建镜像，不允许在预发机器上从工作区构建。

COMPOSE_PROJECT_NAME=shelook-staging
APP_ENV=staging
DEBUG=false
APP_VERSION=1.1.0
APP_REVISION=
DEPLOYMENT_REGION=
LOG_LEVEL=INFO

# 不可变镜像：使用仓库地址加 digest，例如 registry.example.com/shelook/backend@sha256:...
BACKEND_IMAGE=
FRONTEND_IMAGE=

# 运行时与数据服务凭据（必须全部替换为受控密钥）。
SECRET_KEY=
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=
POSTGRES_USER=shelook
POSTGRES_PASSWORD=
POSTGRES_DB=shelook
REDIS_PASSWORD=
MINIO_ROOT_USER=shelook
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=shelook
MINIO_SECRET_KEY=
MINIO_BUCKET=product-images
MINIO_PRIVATE_BUCKET=product-images-private
MINIO_PUBLIC_BASE_URL=
DATABASE_MIGRATION_URL=

# 仅允许企业身份源；显式配置一个或多个提供商及租户映射。
ENABLE_AUTH=true
CORS_ORIGINS=
TRUSTED_PROXY_HOSTS=nginx
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
FEISHU_TENANT_KEY_MAP={}
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=
OIDC_TENANT_CLAIM_MAP={}

# 预发也禁止生成 mock；C2PA 文件和 Prometheus 指标密钥以 Docker secret 文件提供。
ALLOW_GENERATION_MOCKS=false
C2PA_ENABLED=true
C2PA_REQUIRED=true
C2PA_CERT_FILE=./secrets/c2pa-cert.pem
C2PA_PRIVATE_KEY_FILE=./secrets/c2pa-private-key.pem
METRICS_API_KEY=
METRICS_API_KEY_FILE=./secrets/metrics-api-key
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://grafana.staging.example.com/grafana/

# 业务供应商 API 凭据在部署后由租户管理员通过“外部 API 配置”页面维护。
