# SheLook 生产环境模板。
#
# 创建 `.env.prod` 后，从受控密钥管理系统填入所有空值。生产发布只允许使用
# 已扫描、可追溯的不可变镜像（仓库地址 + digest），不从部署主机的源码构建。
# `.env.prod`、证书和 secret 文件均不得提交。

COMPOSE_PROJECT_NAME=shelook-prod
APP_ENV=production
DEBUG=false
APP_VERSION=1.1.0
APP_REVISION=
DEPLOYMENT_REGION=
LOG_LEVEL=WARNING

BACKEND_IMAGE=
FRONTEND_IMAGE=

# 生产凭据：禁止使用开发默认值或弱口令。
SECRET_KEY=
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=
POSTGRES_USER=shelook
POSTGRES_PASSWORD=
POSTGRES_DB=shelook
REDIS_PASSWORD=
MINIO_ROOT_USER=shelook
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=shelook
MINIO_SECRET_KEY=
MINIO_BUCKET=product-images
MINIO_PRIVATE_BUCKET=product-images-private
MINIO_PUBLIC_BASE_URL=
# 仅 migrate 服务使用该 schema-owner URL；API/Worker 使用受限运行账号。
DATABASE_MIGRATION_URL=

# 企业身份与网络边界。
ENABLE_AUTH=true
CORS_ORIGINS=
TRUSTED_PROXY_HOSTS=nginx
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
FEISHU_TENANT_KEY_MAP={}
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=
OIDC_TENANT_CLAIM_MAP={}

# 生产内容可信与监控要求。
ALLOW_GENERATION_MOCKS=false
C2PA_ENABLED=true
C2PA_REQUIRED=true
C2PA_CERT_FILE=./secrets/c2pa-cert.pem
C2PA_PRIVATE_KEY_FILE=./secrets/c2pa-private-key.pem
METRICS_API_KEY=
METRICS_API_KEY_FILE=./secrets/metrics-api-key
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=https://grafana.example.com/grafana/

# 业务供应商 API 凭据在部署后由租户管理员通过“外部 API 配置”页面维护。
