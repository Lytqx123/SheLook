# ============================================================
# SheLook Git 忽略规则
#
# 组织顺序: 操作系统 → IDE/编辑器 → 环境变量 → 前端
#           → Python → 虚拟环境 → 日志 → 构建产物
#           → Docker 数据 → Celery → AI 模型 → 临时文件 → 密钥
# ============================================================


# ---- 操作系统 ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# ---- IDE 与编辑器 ----
.vscode/
.idea/
.codebuddy/
.fleet/
.history/
.cursor/
.claude/
.trae/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project


# ---- 环境变量 ----
.env
secrets/*.pem
.env.*
!.env.example
!.env.*.example
.env.local
.env.development.local
.env.test.local
.env.production.local


# ---- Node.js / 前端 ----
node_modules/
.pnp/
.pnp.js
.pnp.*
.yarn/*
